{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome で開く",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "powershell.exe",
      "runtimeArgs": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\open.ps1"
      ],
      "console": "integratedTerminal"
    }
  ]
}
